# ============================================================
# Database
# ============================================================
# Local Docker Compose Postgres (see docker-compose.yml)
DATABASE_URL="postgresql://reos:reos@localhost:5433/real_estate_os?schema=public"
DIRECT_URL="postgresql://reos:reos@localhost:5433/real_estate_os?schema=public"

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================================
# Encryption (REQUIRED)
# Generate with:  openssl rand -hex 32
# Must be 64 hex chars = 32 bytes. This is the master key from
# which per-payload AES-256-GCM keys are derived via scrypt.
# ============================================================
ENCRYPTION_KEY=""

# ============================================================
# Google OAuth (Gmail, Calendar, Drive)
# Create at https://console.cloud.google.com/apis/credentials
# Redirect URI must match exactly:
# ============================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# ============================================================
# Follow Up Boss
# API key: Settings -> API -> Generate Key
# X-System: any short identifier for your app, e.g. "real-estate-os"
# ============================================================
FUB_API_KEY=""
FUB_SYSTEM_KEY="real-estate-os"
FUB_WEBHOOK_SECRET=""

# ============================================================
# AI providers (optional for MVP foundation; wire up in Phase 4)
# ============================================================
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ============================================================
# Storage (optional; Phase 4)
# ============================================================
S3_BUCKET_NAME=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="us-east-1"

# ============================================================
# Redis / Background jobs (optional; Phase 5)
# ============================================================
REDIS_URL="redis://localhost:6379"
WORKER_ENABLED="false"
SYNC_INTERVAL_MINUTES="30"
