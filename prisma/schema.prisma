// Real Estate Operating System — Prisma schema
// Ported from architecture artifact with the following fixes applied:
//   1. CalendarEvent was missing accountId; two relations were both pointing at `transactionId`.
//      Added accountId + separate Account relation.
//   2. AutomationAuditLog was missing accountId; Account relation was bound to `transactionId`.
//      Added accountId + separate Account relation.
//   3. Orphan @@index block at file bottom moved INSIDE the correct models.
//   4. Added missing back-relations on CalendarEvent / AutomationAuditLog from Account.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================================================
// CORE ENTITIES
// ==================================================

model Account {
  id                              String   @id @default(cuid())
  businessName                    String   @map("business_name")
  ownerUserId                     String   @map("owner_user_id")
  followUpBossApiKeyEncrypted     String?  @map("follow_up_boss_api_key_encrypted")
  followUpBossSystemKeyEncrypted  String?  @map("follow_up_boss_system_key_encrypted")
  googleOauthTokensEncrypted      String?  @map("google_oauth_tokens_encrypted")
  /// Meta (Facebook + Instagram) OAuth payload — encrypted JSON
  /// containing the user-level long-lived token, the user's email,
  /// and the list of Pages they granted access to (each with its own
  /// page-scoped long-lived token and optional linked Instagram
  /// Business account). Shape: StoredMetaTokens (MetaOAuthService.ts).
  metaOauthTokensEncrypted        String?  @map("meta_oauth_tokens_encrypted")
  /// LinkedIn OAuth payload — encrypted JSON containing the access
  /// token, refresh token (when granted), and the LinkedIn member URN
  /// we POST as. Shape: StoredLinkedInTokens (LinkedInOAuthService.ts).
  linkedinOauthTokensEncrypted    String?  @map("linkedin_oauth_tokens_encrypted")
  /// Real Broker (Rezen) connection — encrypted JSON
  /// { accessToken (JWT), userId, email, connectedAt }. Set when the
  /// owner connects their Real account in Settings → Integrations;
  /// used to push documents into Rezen checklists via sherlock.
  realApiTokensEncrypted          String?  @map("real_api_tokens_encrypted")
  socialPostTemplates             SocialPostTemplate[]
  settingsJson                    Json?    @map("settings_json")
  /// Brokerage profile this account belongs to. Drives compliance
  /// checklist, CDA template, and default integrations. Nullable
  /// during onboarding before the wizard runs.
  brokerageProfileId              String?  @map("brokerage_profile_id")
  brokerageProfile                BrokerageProfile? @relation(fields: [brokerageProfileId], references: [id])
  /// Subscription state — populated by Stripe webhook. Tier drives
  /// feature gating (free=read-only, solo/team/brokerage unlock
  /// progressively). status mirrors Stripe's subscription status
  /// (active, trialing, past_due, canceled, incomplete).
  subscriptionTier                String   @default("free") @map("subscription_tier")
  subscriptionStatus              String?  @map("subscription_status")
  /// Investor-module entitlements (spec §1). Independent of
  /// subscriptionTier (which gates billing). JSON array of:
  /// "retail_tc" | "investor". Null is treated as ["retail_tc"] by
  /// lib/entitlements.ts so every existing account keeps working
  /// unchanged. An agent-investor holds BOTH on one unified account.
  entitlementsJson                Json?    @map("entitlements_json")
  stripeCustomerId                String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId            String?  @unique @map("stripe_subscription_id")
  subscriptionRenewsAt            DateTime? @map("subscription_renews_at")
  /// When the owner clicked "Delete account" in Settings → Account.
  /// Stripe subscription is canceled at that moment; the row + all
  /// tenant data is kept for 30 days so the owner can restore via
  /// /api/account/restore. After 30 days the scheduled purge route
  /// hard-deletes the Account (cascade-removes contacts, txns, etc.).
  /// Null = active account.
  deletionRequestedAt             DateTime? @map("deletion_requested_at")
  createdAt                       DateTime @default(now()) @map("created_at")
  updatedAt                       DateTime @updatedAt @map("updated_at")

  users                     User[]
  contacts                  Contact[]
  formTemplates             FormTemplate[]
  transactions              Transaction[]
  assets                    Asset[]
  projects                  Project[]
  drawSchedules             DrawSchedule[]
  capitalStackEntries       CapitalStackEntry[]
  sourceChannels            SourceChannel[]
  marketingSpends           MarketingSpend[]
  calendarEvents            CalendarEvent[]
  automationAuditLogs       AutomationAuditLog[]
  pendingEmailMatches       PendingEmailMatch[]
  pendingClosingDateUpdates PendingClosingDateUpdate[]
  forwardedDocuments        ForwardedDocument[]
  esignRequests             EsignRequest[]
  invoiceEntries            InvoiceEntry[]
  emailTemplates            EmailTemplate[]
  leadIntakes               LeadIntake[]
  scanRuns                  ScanRun[]
  helpQuestions             HelpQuestion[]
  pushSubscriptions         PushSubscription[]
  memberships               AccountMembership[]
  taskTemplates             TaskTemplate[]
  complianceTemplates       ComplianceTemplate[]

  @@map("accounts")
}

/// NextAuth.js Account / Session / VerificationToken models plus our
/// own User (extended with role + email + image fields). Email =
/// auth identity; accountId = which REOS tenant the user belongs to.
model AuthAccount {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// User-defined (or AI-generated) reusable task checklist. Applied to a
/// transaction to create its Tasks. itemsJson is an array of:
///   { title, description?, assignedTo, priority,
///     relatesToMilestone?, offsetFromMilestoneDays?, sideFilter? }
/// — same shape as the built-in code templates (TaskTemplates.ts), so
/// apply logic + relative-date derivation are identical.
model TaskTemplate {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")
  name            String
  description     String?
  itemsJson       Json     @map("items_json")
  source          String   @default("manual") // manual | ai
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("task_templates")
}

/// User-defined (or AI-generated) compliance document checklist. When
/// applied to a transaction, its items become that deal's required-doc
/// audit (Transaction.complianceTemplateJson) — overriding the brokerage
/// default for that deal only. itemsJson is an array of:
///   { key, label, keywords: string[], sides?: ("buy"|"sell"|"both")[], detail? }
model ComplianceTemplate {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")
  name            String
  description     String?
  itemsJson       Json     @map("items_json")
  source          String   @default("manual") // manual | ai
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("compliance_templates")
}

/// A user-authored email queued to send at a future time (Gmail-style
/// "send later"). The hourly tick claims due rows atomically (status
/// pending → sending) and sends once via the account's Gmail.
model ScheduledEmail {
  id             String    @id @default(cuid())
  accountId      String    @map("account_id")
  transactionId  String    @map("transaction_id")
  createdByUserId String?  @map("created_by_user_id")
  fromEmail      String    @map("from_email")
  toJson         Json      @map("to_json")
  ccJson         Json?     @map("cc_json")
  subject        String
  body           String
  sendAt         DateTime  @map("send_at")
  status         String    @default("pending") // pending | sending | sent | failed | canceled
  attempts       Int       @default(0)
  lastError      String?   @map("last_error")
  sentAt         DateTime? @map("sent_at")
  gmailMessageId String?   @map("gmail_message_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([status, sendAt])
  @@index([transactionId])
  @@map("scheduled_emails")
}

model User {
  id            String    @id @default(cuid())
  // Nullable because NextAuth's PrismaAdapter.createUser() only
  // provides {name, email, emailVerified}. Our events.createUser
  // callback fills accountId + role immediately after, so in practice
  // the null window lasts a single await. Queries should treat this
  // as "expect populated" and assert on it where that matters.
  accountId     String?   @map("account_id")
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  role          String    @default("owner") // owner, admin, coordinator, assistant, tc, agent
  termsAcceptedAt DateTime? @map("terms_accepted_at")
  // Per-user Telegram link. telegramChatId is the user's private chat
  // with @REOSAtlasBot — inbound messages from that chat resolve to
  // THIS user (and their active account). telegramLinkCode is a one-
  // time deep-link token consumed by /start <code> during linking.
  telegramChatId   String?   @unique @map("telegram_chat_id")
  telegramLinkCode String?   @unique @map("telegram_link_code")
  telegramLinkedAt DateTime? @map("telegram_linked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  account      Account?            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  authAccounts AuthAccount[]
  sessions     Session[]
  auditLogs    AutomationAuditLog[]
  assignedTransactions Transaction[] @relation("AssignedTransactions")
  pushSubscriptions    PushSubscription[]
  memberships          AccountMembership[]
  authoredNotes        TransactionNote[]

  @@index([accountId])
  @@map("users")
}

// ==================================================
// CRM / CONTACT ENTITIES
// ==================================================

model Contact {
  id                 String   @id @default(cuid())
  accountId          String   @map("account_id")
  fubPersonId        String?  @unique @map("fub_person_id")
  fullName           String   @map("full_name")
  primaryEmail       String?  @map("primary_email")
  primaryPhone       String?  @map("primary_phone")
  assignedAgentName  String?  @map("assigned_agent_name")
  sourceName         String?  @map("source_name")
  tagsJson           Json?    @map("tags_json")
  /// Investor-module contact roles (spec §2, §7). JSON array of role
  /// strings: buyer | seller | buyer_agent | lender | private_money_lender
  /// | contractor | title_co | inspector | cash_buyer | tenant | partner.
  /// One contact, many roles across many deals — this is the account-wide
  /// role set, distinct from TransactionParticipant.role (per-deal). The
  /// cash-buyers segment (wholesale disposition) queries this array.
  rolesJson          Json?    @map("roles_json")
  rawFubPayloadJson  Json?    @map("raw_fub_payload_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  participantRoles TransactionParticipant[]
  capitalStackEntries CapitalStackEntry[]

  @@index([accountId])
  @@index([fubPersonId], map: "idx_contacts_fub_person")
  @@map("contacts")
}

// ==================================================
// TRANSACTION ENTITIES
// ==================================================

model Transaction {
  id                     String    @id @default(cuid())
  accountId              String    @map("account_id")
  contactId              String    @map("contact_id")
  /// Investor-module spine (spec §2). Nullable parent Asset — shadow /
  /// incremental reparenting: existing retail transactions run with
  /// assetId=null and every legacy query is unaffected. New investor
  /// deals (and lazily-backfilled retail deals) point at an Asset. For
  /// retail the Asset is degenerate (1 Asset → 1 Transaction, dies at
  /// close); for investors an Asset carries 1..n transactions over its
  /// life (acquire → refi → sell). Backfill: scripts/backfill-assets.ts.
  assetId                String?   @map("asset_id")
  fubPersonId            String?   @map("fub_person_id")
  fubDealId              String?   @map("fub_deal_id")
  /// Rezen (Real Broker) transaction UUID — pasted from the Bolt
  /// dashboard URL (.../transactions/<uuid>). Used as parentId when
  /// looking up this deal's Rezen checklist for the "Send to Rezen"
  /// document push. parentType TRANSACTION (or LISTING for sell-side).
  rezenTransactionId     String?   @map("rezen_transaction_id")
  /// Last successful Send-to-Rezen push timestamp + JSON summary
  /// { pushed, skipped, matchedItems } for the panel's status line.
  rezenLastPushAt        DateTime? @map("rezen_last_push_at")
  rezenLastPushJson      Json?     @map("rezen_last_push_json")
  propertyAddress        String?   @map("property_address")
  city                   String?
  state                  String?
  zip                    String?
  transactionType        String    @default("buyer") @map("transaction_type") // buyer, seller, investor, wholesale, other
  side                   String?
  status                 String    @default("active") // listing, active, pending, closed, dead
  pipelineName           String?   @map("pipeline_name")
  stageName              String?   @map("stage_name")
  contractDate           DateTime? @map("contract_date")
  closingDate            DateTime? @map("closing_date")
  listDate               DateTime? @map("list_date")
  listingExpirationDate  DateTime? @map("listing_expiration_date")
  listPrice              Float?    @map("list_price")
  inspectionDate         DateTime? @map("inspection_date")
  inspectionObjectionDate DateTime? @map("inspection_objection_date")
  appraisalDate          DateTime? @map("appraisal_date")
  financingDeadline      DateTime? @map("financing_deadline")
  titleDeadline          DateTime? @map("title_deadline") // title commitment
  titleObjectionDate     DateTime? @map("title_objection_date")
  possessionDate         DateTime? @map("possession_date")
  earnestMoneyDueDate    DateTime? @map("earnest_money_due_date")
  /// Earnest money dollar amount from the contract (e.g. 1000.00).
  /// The AI reads it but had nowhere to live before — deal-level
  /// alongside the due date. Displayed on the deal + used in wire /
  /// earnest-money verification workflows.
  earnestMoneyAmount     Float?    @map("earnest_money_amount")
  walkthroughDate        DateTime? @map("walkthrough_date")
  lenderName             String?   @map("lender_name")
  titleCompanyName       String?   @map("title_company_name")
  attorneyName           String?   @map("attorney_name")
  notesSummary           String?   @map("notes_summary")
  riskScore              Float     @default(0) @map("risk_score")
  missingItemsJson       Json?     @map("missing_items_json")
  /// Hide this transaction from Production / Digest / Sources rollups
  /// without deleting it. Use for migrated deals whose closingDate is
  /// stamped wrong (e.g. legacy 2025 closing imported with today's date)
  /// or one-off non-production deals (referrals out, training files).
  excludeFromProduction  Boolean   @default(false) @map("exclude_from_production")
  /// Demo / sandbox transaction — generated for testing. Excluded
  /// from every analytics rollup; tagged with a badge in the UI.
  /// Wiped via Settings → Demo data → Reset.
  isDemo                 Boolean   @default(false) @map("is_demo")

  /// Utility Connect enrollment refs (set after a successful POST /lead).
  /// Presence of utilityConnectLeadId is the idempotency key — the
  /// scheduler skips this transaction once enrolled.
  utilityConnectCustomerId      Int?      @map("utility_connect_customer_id")
  utilityConnectLeadId          String?   @map("utility_connect_lead_id")
  utilityConnectReferenceCode   String?   @map("utility_connect_reference_code")
  utilityConnectEnrolledAt      DateTime? @map("utility_connect_enrolled_at")
  lastMeaningfulTouchAt  DateTime? @map("last_meaningful_touch_at")
  lastSyncedAt           DateTime? @map("last_synced_at")
  rawSourceJson          Json?     @map("raw_source_json")
  aiSummary              String?   @map("ai_summary")
  aiSummaryUpdatedAt     DateTime? @map("ai_summary_updated_at")
  // SmartFolder: per-transaction Gmail folder + auto-filter (2026+ txns only)
  smartFolderLabelId     String?   @map("smart_folder_label_id")
  smartFolderFilterId    String?   @map("smart_folder_filter_id")
  smartFolderSetupAt     DateTime? @map("smart_folder_setup_at")
  smartFolderBackfillCount Int?    @map("smart_folder_backfill_count")
  /// Who's the TC / assigned coordinator on this deal. Drives /today
  /// and /transactions "my queue" filters. Nullable = unassigned
  /// (defaults to the creating user on auto-create). Defer-SET so we
  /// don't block on a user row during transaction auto-create paths.
  assignedUserId         String?   @map("assigned_user_id")
  /// Per-deal visibility lock. When true, this deal is hidden from
  /// everyone EXCEPT the assigned user (assignedUserId) and account
  /// owners/admins — used for sensitive deals (e.g. the owner's own
  /// principal/investor deals). Default false = account-wide visible,
  /// so existing deals are unchanged. Enforced on every discovery/view
  /// surface via lib/deal-visibility.ts.
  restrictedToAssignee   Boolean   @default(false) @map("restricted_to_assignee")
  // Applied compliance template — per-deal required-doc checklist that
  // overrides the brokerage default for this deal only. Null = use the
  // account/brokerage resolution.
  complianceTemplateJson Json?     @map("compliance_template_json")
  complianceTemplateName String?   @map("compliance_template_name")
  // Contract extraction: pending review + last applied timestamp
  pendingContractJson    Json?     @map("pending_contract_json")
  contractExtractedAt    DateTime? @map("contract_extracted_at")
  contractAppliedAt      DateTime? @map("contract_applied_at")
  /// Snapshot of the last DocumentSynthesisService run — merged
  /// timeline dates, contingency statuses, and what changed — so the
  /// deal's "current state" panel renders without re-running synthesis.
  synthesisJson          Json?     @map("synthesis_json")
  synthesizedAt          DateTime? @map("synthesized_at")
  // Contract lifecycle: offer -> counter -> executed. Calendar sync
  // gated until stage="executed" since pre-executed dates may shift.
  contractStage          String?   @map("contract_stage") // offer | counter | executed | unknown
  buyerSignedAt          DateTime? @map("buyer_signed_at")
  sellerSignedAt         DateTime? @map("seller_signed_at")
  // Public share link for the read-only timeline view
  shareToken             String?   @unique @map("share_token")
  shareCreatedAt         DateTime? @map("share_created_at")
  shareExpiresAt         DateTime? @map("share_expires_at")
  /// Stamped every time a human edits the transaction (parties,
  /// dates, financials, etc.). Anti-overwrite guard: when set, AI
  /// re-extraction paths must NOT silently rewrite fields — they
  /// queue a PendingContractUpdate / PendingClosingDateUpdate row
  /// for human review instead. Cleared by an explicit "re-apply"
  /// from the user.
  manuallyEditedAt       DateTime? @map("manually_edited_at")
  // External transaction-management forwarding (Dotloop, Rezen, SkySlope)
  forwardingEmail        String?   @map("forwarding_email")
  forwardingEmailProvider String?  @map("forwarding_email_provider") // "dotloop", "rezen", "skyslope", "other"
  forwardingLastRunAt    DateTime? @map("forwarding_last_run_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  account             Account                  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact             Contact                  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  asset               Asset?                   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  milestones          Milestone[]
  tasks               Task[]
  documents           Document[]
  extractedDates      ExtractedDate[]
  communicationEvents CommunicationEvent[]
  calendarEvents      CalendarEvent[]
  automationAuditLogs AutomationAuditLog[]
  attributions        TransactionAttribution[]
  financials          TransactionFinancials?
  forwardedDocuments  ForwardedDocument[]
  invoiceEntries      InvoiceEntry[]
  participants        TransactionParticipant[]
  wireVerifications   WireVerification[]
  contractVersions    ContractExtractionVersion[]
  inspections         TransactionInspection[]
  notes               TransactionNote[]
  esignRequests       EsignRequest[]
  assignedUser        User?                    @relation("AssignedTransactions", fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([assetId], map: "idx_transactions_asset")
  @@index([contactId, status], map: "idx_transactions_contact_status")
  @@index([status, closingDate], map: "idx_transactions_status_closing")
  @@map("transactions")
}

// ==================================================
// INVESTOR MODULE — ASSET SPINE (spec §2)
// The Asset (Deal) is the top-level object for investor deals; a
// property persists across many episodes (acquire → rehab → refi →
// rent → sell). Transactions and Projects are CHILDREN. For retail the
// Asset is degenerate (1:1 with its Transaction). Added Phase 0; the
// forks it drives (lifecycle template, economics, comms cadence) come
// online with each strategy phase.
// ==================================================

model Asset {
  id          String  @id @default(cuid())
  accountId   String  @map("account_id")
  /// Owning user (investor of record). Null = unassigned.
  ownerUserId String? @map("owner_user_id")
  address     String?

  // ── Classification (spec §3–5). Set by auto-detect at intake. ──
  /// agency (retail, third-party client) | principal (you own the asset)
  representation       String  @default("agency")
  /// takes_title | assignment | double_close | contract_rights (spec §4).
  /// Governs whether an ownership record + holding-cost meter are created
  /// and how many closings are coordinated.
  titlePath            String? @map("title_path")
  /// retail | flip | wholesale | rental_brrrr | creative (spec §6)
  strategy             String  @default("retail")
  /// subject_to | seller_finance | lease_option | wrap — set only when
  /// strategy=creative (spec §6.4, §13).
  creativeSubstructure String? @map("creative_substructure")

  /// Free-text stage name from the active strategy template's lifecycle.
  /// The template/stage engine (auto-advance) lands with Phase 1.
  currentStageName     String? @map("current_stage_name")
  riskScore            Float   @default(0) @map("risk_score")
  /// Per-strategy economics object (spec §9). Shape varies by strategy:
  /// retail=GCI, flip=profit/ROI, wholesale=assignment fee, etc.
  economicsJson        Json?   @map("economics_json")
  /// Hybrid principal+commission deals (spec §1): you own the asset AND
  /// earn an agency commission component (e.g. list your own flip).
  agencyComponentJson  Json?   @map("agency_component_json")
  /// Integration handles (spec §7, §11). Drive folder tree + Google Chat
  /// deal space — auto-scaffolded with their respective phases.
  driveFolderId        String? @map("drive_folder_id")
  chatSpaceId          String? @map("chat_space_id")
  status               String  @default("active") // active | archived
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  account       Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  projects      Project[]
  tasks         Task[]
  drawSchedules DrawSchedule[]
  draws         Draw[]
  capitalStack  CapitalStackEntry[]

  @@index([accountId])
  @@index([accountId, strategy], map: "idx_assets_account_strategy")
  @@index([accountId, representation], map: "idx_assets_account_representation")
  @@map("assets")
}

model Project {
  id          String  @id @default(cuid())
  assetId     String  @map("asset_id")
  accountId   String  @map("account_id")
  /// rehab | lease_up | servicing | stabilization | other (spec §2, §6).
  type        String
  status      String  @default("active") // active | complete | archived
  budget      Float?
  actual      Float?
  /// Draw schedule + capital stack relations land with Phase 2 (Flip).
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([accountId])
  @@map("projects")
}

// ==================================================
// INVESTOR MODULE — DRAW ENGINE (spec §2, §7)
// Rehab draws tied to milestones, gated by a lien waiver before
// release, with retainage (~10%) held back to punch-list. Used by Flip
// and BRRRR renovation stages.
// ==================================================

model DrawSchedule {
  id               String   @id @default(cuid())
  assetId          String   @map("asset_id")
  accountId        String   @map("account_id")
  /// Retainage withheld from each release until punch-list (spec §7).
  retainagePercent Float    @default(10) @map("retainage_percent")
  /// Total rehab budget this schedule draws against (optional).
  totalBudget      Float?   @map("total_budget")
  status           String   @default("active") // active | complete
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  draws   Draw[]

  @@index([assetId])
  @@index([accountId])
  @@map("draw_schedules")
}

model Draw {
  id               String    @id @default(cuid())
  drawScheduleId   String    @map("draw_schedule_id")
  assetId          String    @map("asset_id")
  /// Milestone this draw is tied to (e.g. "demo complete", "rough-in").
  milestone        String
  amount           Float
  /// requested → verified (photos) → lien_waiver_received → released
  /// (retainage withheld) → paid. The lien-waiver gate blocks release
  /// until lienWaiverDocId is set.
  status           String    @default("requested")
  lienWaiverDocId  String?   @map("lien_waiver_doc_id")
  verifyPhotosJson Json?     @map("verify_photos_json")
  /// Dollar amount of retainage held back from this draw's release.
  retainageHeld    Float?    @map("retainage_held")
  /// Lender's release reference / confirmation id.
  lenderReleaseRef String?   @map("lender_release_ref")
  requestedAt      DateTime? @map("requested_at")
  verifiedAt       DateTime? @map("verified_at")
  releasedAt       DateTime? @map("released_at")
  paidAt           DateTime? @map("paid_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  schedule DrawSchedule @relation(fields: [drawScheduleId], references: [id], onDelete: Cascade)
  asset    Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([drawScheduleId])
  @@index([assetId])
  @@map("draws")
}

// ==================================================
// INVESTOR MODULE — CAPITAL STACK (spec §2, §7)
// The funding sources on a deal — private money, bridge, DSCR, seller
// note, underlying loan (sub-to). Lenders are Contacts.
// ==================================================

model CapitalStackEntry {
  id              String    @id @default(cuid())
  assetId         String    @map("asset_id")
  accountId       String    @map("account_id")
  lenderContactId String?   @map("lender_contact_id")
  /// private_money | bridge | dscr | seller_note | underlying_loan
  type            String
  principal       Float?
  /// Annual interest rate as a human percent (e.g. 10 = 10%).
  rate            Float?
  balloonDate     DateTime? @map("balloon_date")
  payoffBalance   Float?    @map("payoff_balance")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  asset   Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lender  Contact? @relation(fields: [lenderContactId], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([accountId])
  @@map("capital_stack_entries")
}

// ==================================================
// ATLAS AGENT — pending confirmations (spec: confirm-before-write)
// A write the agent proposes over a stateless channel (Telegram) is
// parked here until the user replies "yes". One pending set per
// (account, user, channel); a new proposal replaces the old.
// ==================================================

model AtlasPendingAction {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  userId      String   @map("user_id")
  channel     String   @default("telegram")
  /// Array of { tool, args, preview } awaiting confirmation.
  actionsJson Json     @map("actions_json")
  summary     String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([accountId, userId, channel])
  @@map("atlas_pending_actions")
}

model Milestone {
  id              String    @id @default(cuid())
  transactionId   String    @map("transaction_id")
  type            String    // contract, inspection, appraisal, financing, title, closing, etc.
  label           String
  /// NULL means "tracked as a checklist item without a scheduled date".
  /// The timeline renders these as "needs date", calendar sync skips
  /// them, and the user can fill a real date later from the timeline UI.
  /// Template-seeded milestones (appraisal, financing-approved, etc.)
  /// default to null — we never fabricate offset-from-contract dates
  /// that weren't actually in the contract.
  dueAt           DateTime? @map("due_at")
  completedAt     DateTime? @map("completed_at")
  status          String    @default("pending") // pending, completed, overdue, cancelled
  ownerRole       String    @default("agent") @map("owner_role") // agent, lender, title, inspector, client
  source          String    @default("manual") // manual, extracted, fub_sync, calendar_sync
  confidenceScore Float     @default(1.0) @map("confidence_score")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([transactionId, type], map: "idx_milestones_transaction_type")
  @@index([transactionId, dueAt], map: "idx_milestones_transaction_due")
  @@map("milestones")
}

model Task {
  id            String    @id @default(cuid())
  transactionId String    @map("transaction_id")
  milestoneId   String?   @map("milestone_id")
  /// Investor module (spec §2, §6): when this task was instantiated
  /// from a strategy stage template, assetId links it to the Asset and
  /// stageKey records which stage produced it (drives auto-advance —
  /// a stage completes when all its non-auto tasks are done). Null for
  /// ordinary retail TC tasks.
  assetId       String?   @map("asset_id")
  stageKey      String?   @map("stage_key")
  /// Template task key (StageTemplate.tasks[].key) — dedupes
  /// re-instantiation of the same stage.
  templateKey   String?   @map("template_key")
  fubTaskId     String?   @unique @map("fub_task_id")
  title         String
  description   String?
  dueAt         DateTime? @map("due_at")
  completedAt   DateTime? @map("completed_at")
  assignedTo    String?   @map("assigned_to")
  priority      String    @default("normal") // low, normal, high, urgent
  syncStatus    String    @default("pending") @map("sync_status") // pending, synced, failed
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  milestone   Milestone?  @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  asset       Asset?      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([milestoneId])
  @@index([assetId, stageKey], map: "idx_tasks_asset_stage")
  @@index([dueAt, completedAt])
  @@map("tasks")
}

// ==================================================
// DOCUMENT ENTITIES
// ==================================================

model Document {
  id             String   @id @default(cuid())
  transactionId  String   @map("transaction_id")
  category       String?  // contract, addendum, inspection, appraisal, title, closing, other
  fileName       String   @map("file_name")
  mimeType       String   @map("mime_type")
  storageUrl     String?  @map("storage_url")
  /// Raw PDF bytes. Populated on upload OR when a contract is
  /// pulled from Gmail via rescan, so the same doc can be re-
  /// extracted later without refetching. For Cloud Run, migrate
  /// this to GCS blob storage once total corpus >~500MB.
  rawBytes       Bytes?   @map("raw_bytes")
  source         String   @default("upload") // upload, gmail_attachment, fub_attachment
  extractedText  String?  @map("extracted_text")
  /// Cached DocumentSynthesisService analysis (docType, contingency
  /// updates, field changes). Lets a re-synthesis reuse the AI read
  /// instead of re-analyzing the (immutable) PDF every time.
  analysisJson   Json?    @map("analysis_json")
  uploadOrigin   String?  @map("upload_origin")
  /// AI-classified Rezen slot key (e.g. "earnest_money_receipt").
  /// Populated by DocumentClassifierService; null = unclassified.
  /// Drives Rezen prep matching when filename keywords miss.
  suggestedRezenSlot       String?   @map("suggested_rezen_slot")
  suggestedRezenConfidence Float?    @map("suggested_rezen_confidence")
  classifiedAt             DateTime? @map("classified_at")
  /// For Gmail-sourced docs — source message internalDate so we
  /// can pick the newest when multiple contracts exist on one txn.
  sourceDate     DateTime? @map("source_date")
  /// Manual Rezen-slot pin. When set, this document is THE document
  /// for that checklist item — takes precedence over AI suggestion
  /// and filename heuristics in buildRezenPrepReport. Cleared by
  /// setting null. Not validated against the slot vocab at the DB
  /// level (slot lists are per-brokerage-profile rows).
  assignedRezenSlot   String?   @map("assigned_rezen_slot")
  /// Signature scan results (GPT-4o vision over the last pages).
  /// status: signed | partial | unsigned | no_signature_blocks
  signatureScanStatus String?   @map("signature_scan_status")
  signatureScanNotes  String?   @map("signature_scan_notes")
  signatureScannedAt  DateTime? @map("signature_scanned_at")
  /// Google Drive file id of the redundant backup copy (DriveBackupService).
  /// Null = not yet backed up (or backup disabled / Drive not connected).
  driveFileId    String?  @map("drive_file_id")
  uploadedAt     DateTime @map("uploaded_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  transaction         Transaction          @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  documentExtractions DocumentExtraction[]
  extractedDates      ExtractedDate[]
  esignRequests       EsignRequest[]

  @@index([transactionId])
  @@map("documents")
}

/// Account-level library of blank forms (offer, counter, addendum,
/// disclosure…) that Atlas fills with a deal's data, then routes to
/// e-sign. Fillable (AcroForm) forms fill exactly; flat forms are
/// flagged (isFlat) for the coordinate-overlay path.
model FormTemplate {
  id         String   @id @default(cuid())
  accountId  String   @map("account_id")
  name       String
  category   String?  // offer, counter, addendum, disclosure, other
  fileName   String   @map("file_name")
  rawBytes   Bytes    @map("raw_bytes")
  /// Cached FormField[] (name+type+options) read from the AcroForm.
  fieldsJson Json?    @map("fields_json")
  fieldCount Int      @default(0) @map("field_count")
  isFlat     Boolean  @default(false) @map("is_flat")
  /// Adobe-only XFA form — renders as the "install Adobe" page to
  /// everything else, so it must be flattened (Adobe Print→PDF) before
  /// it's fillable. Distinct from a usable flat PDF with a text layer.
  isXfa      Boolean  @default(false) @map("is_xfa")
  /// True when a flat PDF has a real text layer (anchors → mapper works).
  hasText    Boolean  @default(false) @map("has_text")
  /// For flat forms: the saved per-field coordinate map (the "set up
  /// once, reuse" placements the mapper produces). Placement[] shape.
  placementsJson Json? @map("placements_json")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("form_templates")
}

model EsignRequest {
  id                    String   @id @default(cuid())
  accountId             String   @map("account_id")
  transactionId          String   @map("transaction_id")
  documentId             String   @map("document_id")
  provider              String   @default("documenso")
  providerEnvelopeId     String?  @map("provider_envelope_id")
  status                String   @default("draft") // draft, sent, completed, rejected, failed
  title                 String
  recipientsJson        Json     @map("recipients_json")
  signingLinksJson      Json?    @map("signing_links_json")
  providerResponseJson  Json?    @map("provider_response_json")
  errorMessage          String?  @map("error_message")
  sentAt                DateTime? @map("sent_at")
  completedAt           DateTime? @map("completed_at")
  /// SHA-256 hex of the finalized (signed) PDF — native provider only.
  finalHash             String?  @map("final_hash")
  /// Document row holding the finalized signed PDF — native provider only.
  finalDocumentId       String?  @map("final_document_id")
  createdByUserId       String?  @map("created_by_user_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  document    Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipients  EsignRecipient[]
  signFields  EsignField[]
  events      EsignEvent[]

  @@index([accountId, status])
  @@index([transactionId, createdAt])
  @@index([documentId])
  @@map("esign_requests")
}

model DocumentExtraction {
  id                String   @id @default(cuid())
  documentId        String   @map("document_id")
  extractionStatus  String   @default("pending") @map("extraction_status") // pending, processing, completed, failed
  extractorVersion  String   @map("extractor_version")
  confidenceScore   Float    @default(0) @map("confidence_score")
  rawOutputJson     Json?    @map("raw_output_json")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  document       Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  extractedDates ExtractedDate[]

  @@index([documentId])
  @@map("document_extractions")
}

model ExtractedDate {
  id                   String   @id @default(cuid())
  transactionId        String   @map("transaction_id")
  documentId           String   @map("document_id")
  documentExtractionId String   @map("document_extraction_id")
  dateType             String   @map("date_type") // contract, closing, inspection, appraisal, financing_deadline, etc.
  extractedValue       String   @map("extracted_value") // raw extracted text
  normalizedValue      DateTime @map("normalized_value")
  sourcePage           Int?     @map("source_page")
  sourceSnippet        String?  @map("source_snippet")
  confidenceScore      Float    @map("confidence_score")
  documentType         String?  @map("document_type")
  matchStatus          String   @default("pending") @map("match_status") // pending, matched, ignored, conflict
  syncStatus           String   @default("pending") @map("sync_status") // pending, synced, rejected
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  transaction        Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  document           Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentExtraction DocumentExtraction @relation(fields: [documentExtractionId], references: [id], onDelete: Cascade)

  @@index([transactionId, dateType], map: "idx_extracted_dates_transaction_type")
  @@index([matchStatus])
  @@map("extracted_dates")
}

// ==================================================
// COMMUNICATION ENTITIES
// ==================================================

model CommunicationEvent {
  id             String   @id @default(cuid())
  transactionId  String   @map("transaction_id")
  type           String   // email, call, text, meeting
  source         String   // gmail, fub, calendar, manual
  subject        String?
  summary        String?
  happenedAt     DateTime @map("happened_at")
  rawPayloadJson Json?    @map("raw_payload_json")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId, happenedAt])
  @@map("communication_events")
}

model CalendarEvent {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")
  transactionId   String?  @map("transaction_id")
  milestoneId     String?  @map("milestone_id")
  googleEventId   String?  @unique @map("google_event_id")
  calendarType    String   @default("external") @map("calendar_type") // private_ops, client_safe, external
  title           String
  startAt         DateTime @map("start_at")
  endAt           DateTime @map("end_at")
  location        String?
  description     String?
  attendeesJson   Json?    @map("attendees_json")
  createdByApp    Boolean  @default(false) @map("created_by_app")
  status          String   @default("active") // active, cancelled
  source          String?  // document_extraction, milestone_auto, manual
  rawPayloadJson  Json?    @map("raw_payload_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  inspections TransactionInspection[]

  @@index([accountId])
  @@index([transactionId])
  @@index([milestoneId])
  @@index([startAt])
  @@map("calendar_events")
}

// ==================================================
// AUTOMATION ENTITIES
// ==================================================

model AutomationAuditLog {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")
  transactionId   String?  @map("transaction_id")
  entityType      String   @map("entity_type") // transaction, task, milestone, fub_stage, fub_tag
  entityId        String?  @map("entity_id")
  ruleName        String   @map("rule_name")
  actionType      String   @map("action_type") // create, update, sync, suggest
  sourceType      String   @map("source_type") // document_extraction, email_analysis, calendar_sync, manual
  confidenceScore Float    @map("confidence_score")
  decision        String   // applied, suggested, rejected, failed
  beforeJson      Json?    @map("before_json")
  afterJson       Json?    @map("after_json")
  actorUserId     String?  @map("actor_user_id") // null = system / cron / webhook
  createdAt       DateTime @default(now()) @map("created_at")

  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  actor       User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([transactionId])
  @@map("automation_audit_logs")
}

// ==================================================
// MARKETING / SOURCE ENTITIES
// ==================================================

model SourceChannel {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  name      String
  category  String   // paid, organic, referral, sphere, direct_mail, youtube, ppc, portal, open_house, repeat_client, other
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account         Account                  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  marketingSpends MarketingSpend[]
  attributions    TransactionAttribution[]

  @@index([accountId])
  @@map("source_channels")
}

model MarketingSpend {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")
  sourceChannelId String   @map("source_channel_id")
  spendDate       DateTime @map("spend_date")
  amount          Float
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourceChannel SourceChannel @relation(fields: [sourceChannelId], references: [id], onDelete: Cascade)

  @@index([sourceChannelId, spendDate], map: "idx_marketing_spends_channel_date")
  @@index([accountId])
  @@map("marketing_spends")
}

model TransactionAttribution {
  id              String   @id @default(cuid())
  transactionId   String   @map("transaction_id")
  sourceChannelId String   @map("source_channel_id")
  attributionType String   @default("primary") @map("attribution_type") // primary, secondary
  weight          Float    @default(1.0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  sourceChannel SourceChannel @relation(fields: [sourceChannelId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([sourceChannelId])
  @@map("transaction_attributions")
}

// ==================================================
// FINANCIAL ENTITIES
// ==================================================

// ==================================================
// PENDING EMAIL MATCHES (title-order detections awaiting manual review)
// ==================================================

model PendingEmailMatch {
  id                 String    @id @default(cuid())
  accountId          String    @map("account_id")
  threadId           String    @unique @map("thread_id")
  subject            String
  fromEmail          String    @map("from_email")
  matchedDomain      String?   @map("matched_domain")
  confidenceScore    Float     @map("confidence_score")
  reasonsJson        Json?     @map("reasons_json")
  extractedBuyer     String?   @map("extracted_buyer")
  extractedSeller    String?   @map("extracted_seller")
  extractedAddress   String?   @map("extracted_address")
  extractedFileNumber String?  @map("extracted_file_number")
  status             String    @default("pending") // pending | resolved | ignored
  resolvedContactId  String?   @map("resolved_contact_id")
  resolvedTransactionId String? @map("resolved_transaction_id")
  resolvedAt         DateTime? @map("resolved_at")
  detectedAt         DateTime  @default(now()) @map("detected_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, status])
  @@index([detectedAt])
  @@map("pending_email_matches")
}

// ==================================================
// PENDING CLOSING-DATE UPDATES
// Queued when a Settlement Statement / Closing Disclosure PDF is
// detected that implies a closing date earlier than the one in FUB.
// ==================================================

model PendingClosingDateUpdate {
  id                 String    @id @default(cuid())
  accountId          String    @map("account_id")
  transactionId      String    @map("transaction_id")
  threadId           String?   @map("thread_id")
  attachmentId       String?   @map("attachment_id")
  documentType       String    @map("document_type") // settlement_statement | closing_disclosure | alta | hud_1 | unknown
  anchor             String    // Which anchor fired in the PDF ("Disbursement Date", etc.)
  extractedDate      DateTime  @map("extracted_date")
  previousDate       DateTime? @map("previous_date")
  // proposedStage: if set, applying also transitions FUB stage + local txn
  // status. Typical value: "Closed" for SS reconciliation.
  proposedStage      String?   @map("proposed_stage")
  // side: which side the contact occupies on THIS deal (buy | sell),
  // so one SS can produce two queue rows (buyer + seller).
  side               String?
  confidence         Float
  snippet            String?
  status             String    @default("pending") // pending | applied | ignored
  appliedAt          DateTime? @map("applied_at")
  detectedAt         DateTime  @default(now()) @map("detected_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([transactionId, extractedDate])
  @@index([accountId, status])
  @@index([detectedAt])
  @@map("pending_closing_date_updates")
}

/// Invoices / bills / receipts detected in a transaction's
/// SmartFolder (inspection fees, HOA docs, home-warranty, utility
/// transfers, etc.). Feeds deal P&L separately from commission-side
/// financials.
model InvoiceEntry {
  id             String    @id @default(cuid())
  accountId      String    @map("account_id")
  transactionId  String?   @map("transaction_id")
  threadId       String    @map("thread_id")
  messageId      String    @map("message_id")
  attachmentId   String?   @map("attachment_id")
  filename       String?
  fromEmail      String?   @map("from_email")
  subject        String?
  vendorName     String?   @map("vendor_name")
  amount         Float?
  invoiceDate    DateTime? @map("invoice_date")
  category       String?   // inspection | hoa | warranty | utility | repair | title | other
  snippet        String?
  status         String    @default("pending") // pending | confirmed | ignored
  detectedAt     DateTime  @default(now()) @map("detected_at")

  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@unique([accountId, messageId, attachmentId], map: "uniq_invoice_msg_att")
  @@index([accountId, status])
  @@index([transactionId])
  @@map("invoice_entries")
}

/// Canned email templates with mail-merge variables. Populated with a
/// starter set per account on first login; TCs can edit/add.
///
/// Body + subject use {{variable_name}} tokens that get resolved
/// against the current transaction at render time. See
/// EmailMergeService for the full variable list.
model EmailTemplate {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  name        String   // internal reference, e.g. "Welcome to new client"
  subject     String
  body        String   @db.Text
  /// Optional grouping: welcome | inspection | title | clear_to_close |
  /// closing | post_close | review_request | generic
  category    String?
  /// Array of party roles to populate as the default To field when
  /// the user picks this template. e.g. ["primary_contact"] for a
  /// client email, ["title"] for an escrow update.
  defaultTo   String[] @default([]) @map("default_to")
  /// If true, this is a starter template seeded by the system;
  /// editable but protected from re-seeding.
  isStarter   Boolean  @default(false) @map("is_starter")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, category])
  @@map("email_templates")
}

/// Per-account social-post caption templates. One row per
/// (event × platform) — when present, SocialPostService renders the
/// template (variable substitution) instead of calling OpenAI for
/// that slot. Empty/missing rows fall back to AI generation.
///
/// Variables supported: {{address}}, {{city}}, {{state}}, {{price}},
/// {{beds}}, {{baths}}, {{sqft}}, {{agent_name}}, {{brokerage_name}},
/// {{event_label}}, {{side_verb}}, {{hashtags}}.
model SocialPostTemplate {
  id           String   @id @default(cuid())
  accountId    String   @map("account_id")
  /// new_listing | under_contract | sold
  event        String
  /// instagram | facebook | linkedin
  platform     String
  body         String   @db.Text
  /// Seeded by the system on first edit; editable but flagged so a
  /// future re-seed can skip user-customized rows.
  isStarter    Boolean  @default(false) @map("is_starter")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, event, platform], map: "uniq_social_post_template_slot")
  @@index([accountId])
  @@map("social_post_templates")
}

/// Pre-listing / pre-offer structured intake. Public `/intake` form
/// posts here — captures name, email, phone, side (buy/sell), property
/// or area of interest, timeline, budget, financing status, and free-
/// text notes. The TC reviews the queue at /settings/intake and
/// promotes good leads to a real Contact + Transaction.
///
/// No auth required to submit (it's a public lead-capture form). We
/// rate-limit at the route level and flag spam via simple content
/// heuristics before allowing promotion.
model LeadIntake {
  id                       String   @id @default(cuid())
  accountId                String   @map("account_id")
  /// "buy" | "sell"
  side                     String
  fullName                 String   @map("full_name")
  email                    String?
  phone                    String?
  /// For sellers — the property they want to list.
  propertyAddress          String?  @map("property_address")
  /// For buyers — area / price range / beds / baths.
  areaOfInterest           String?  @map("area_of_interest") @db.Text
  budget                   String?
  /// When they hope to close / start.
  timeline                 String?
  /// Cash | pre-approved | needs approval | not sure
  financingStatus          String?  @map("financing_status")
  notes                    String?  @db.Text
  /// Where the lead came from — referral, website, open house, etc.
  source                   String?
  /// Optional user-agent / IP snapshot for abuse review.
  submittedUserAgent       String?  @map("submitted_user_agent") @db.Text
  submittedIp              String?  @map("submitted_ip")
  status                   String   @default("new") // new | contacted | converted | dismissed
  /// When a TC promotes the lead to a Transaction, we record the link
  /// so the lead queue can show "already converted" without deleting
  /// the intake row (audit trail preserved).
  convertedTransactionId   String?  @map("converted_transaction_id")
  convertedContactId       String?  @map("converted_contact_id")
  convertedAt              DateTime? @map("converted_at")
  submittedAt              DateTime @default(now()) @map("submitted_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, status, submittedAt(sort: Desc)])
  @@map("lead_intakes")
}

/// Snapshot of a contract extraction at a point in time. Every time
/// /contract/extract or /contract/rescan produces a new extraction,
/// we copy the OUTGOING (prior) version here BEFORE the merge writes
/// the new pendingContractJson.
///
/// Gives the TC an audit trail — "what dates were in the original
/// contract vs what was in the amendment?" — and drives the diff
/// viewer that shows counter-offer / addendum changes field-by-field.
model ContractExtractionVersion {
  id             String   @id @default(cuid())
  transactionId  String   @map("transaction_id")
  /// The full extraction JSON at this version. Same shape as
  /// Transaction.pendingContractJson — { field: { value, confidence,
  /// snippet } }.
  extractionJson Json     @map("extraction_json")
  /// Where the PDF came from. upload | rescan_gmail | rescan_stored
  /// | auto_apply (contract/apply). Matches _rescan.source in the
  /// extraction metadata.
  source         String
  /// Filename of the PDF that produced this version (if known).
  filename       String?
  /// internalDate from Gmail for gmail-sourced versions; uploadedAt
  /// otherwise. Drives chronological ordering in the diff viewer.
  sourceDate     DateTime @map("source_date")
  createdAt      DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId, createdAt(sort: Desc)])
  @@map("contract_extraction_versions")
}

/// Compliance record of the TC verifying wire instructions by voice
/// call before closing. Proof the brokerage followed its own wire-
/// fraud prevention protocol — liability is six-figure if wire
/// instructions turn out to have been spoofed, so we log every
/// verification with who, when, called number, and a summary of what
/// was confirmed.
///
/// Typical workflow: before a client sends closing funds, the TC
/// phones the title officer at a number they KNOW (not from the
/// email that prompted the wire), confirms the wire instructions
/// verbally, and logs it here. REOS never stores actual ABA / account
/// numbers; `instructionsSummary` is a free-text description the TC
/// writes (e.g. "Last 4 of account matches 4823, amount $12,500, no
/// changes since contract").
model WireVerification {
  id                    String   @id @default(cuid())
  transactionId         String   @map("transaction_id")
  verifiedAt            DateTime @map("verified_at")
  /// Which REOS user made the verification call.
  verifiedByUserId      String?  @map("verified_by_user_id")
  /// The person at title/settlement confirmed with.
  titleAgentName        String?  @map("title_agent_name")
  /// Phone number called (owner sourced from a known-good record,
  /// NOT from the email that triggered the wire request).
  phoneCalled           String?  @map("phone_called")
  /// Short free-text summary of what was confirmed. Never store
  /// full ABA / account numbers — this is a liability surface.
  instructionsSummary   String?  @map("instructions_summary") @db.Text
  notes                 String?  @db.Text
  createdAt             DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId, verifiedAt(sort: Desc)])
  @@map("wire_verifications")
}

/// Co-buyers, co-sellers, and other secondary parties on a transaction.
/// The primary contact stays on Transaction.contactId; this table is
/// for EVERY OTHER human tied to the deal — spouses, LLC members,
/// co-signers, lenders (as contacts), attorneys, inspectors, etc.
model TransactionParticipant {
  id            String   @id @default(cuid())
  transactionId String   @map("transaction_id")
  contactId     String   @map("contact_id")
  role          String   // co_buyer | co_seller | lender | attorney | inspector | coordinator | other
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([transactionId, contactId, role], map: "uniq_txn_participant")
  @@index([transactionId])
  @@index([contactId])
  @@map("transaction_participants")
}

/// Per-brokerage configuration. Multi-tenant SaaS hook: each
/// Account picks a profile (or creates one), which defines:
///   - Compliance system + checklist (Rezen / Skyslope / etc.)
///   - CDA template
///   - Default email-template seed pack
///   - Default trusted-sender domains (their own brokerage email)
///
/// State-level overrides ride on top via BrokerageStateConfig.
/// Today: REOS ships with one row pre-seeded — "Real Broker (Rezen)".
model BrokerageProfile {
  id                       String   @id @default(cuid())
  /// Stable slug, unique. e.g. "real-broker", "kw-command", "indie-default".
  slug                     String   @unique
  name                     String   // "Real Broker LLC"
  /// Compliance system. Drives which checklist + CDA template apply.
  complianceSystem         String   // rezen | skyslope | dotloop | lonewolf | inhouse | none
  /// Trusted email domains for this brokerage's agents (used to
  /// distinguish "our agent" from "other-side agent" on inbound mail).
  agentEmailDomains        String[] @default([]) @map("agent_email_domains")
  /// Optional CDA template id (FK omitted for v1 — seeded statically).
  cdaTemplateKey           String?  @map("cda_template_key")
  /// Free-form config bag — provider keys, defaults, etc.
  configJson               Json?    @map("config_json")
  isActive                 Boolean  @default(true) @map("is_active")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  checklists               BrokerageChecklist[]
  stateConfigs             BrokerageStateConfig[]
  accounts                 Account[]

  @@map("brokerage_profiles")
}

/// Compliance checklists, one row per (profile, kind, slot).
/// Replaces the hard-coded TRANSACTION_SLOTS / LISTING_SLOTS in
/// RezenCompliancePrep.ts — the existing 34/14 list is seeded as
/// rows under the "Real Broker (Rezen)" profile.
model BrokerageChecklist {
  id              String   @id @default(cuid())
  profileId       String   @map("profile_id")
  /// "transaction" or "listing".
  kind            String
  slotNumber      Int      @map("slot_number")
  slotKey         String   @map("slot_key")
  label           String
  required        String   // required | if_applicable
  tag             String?  // cda | closing_docs | termination | null
  requiredFor     String?  @map("required_for")
  keywordsJson    Json     @map("keywords_json")
  /// State-scoped override — null = applies to all states.
  stateCode       String?  @map("state_code")

  profile BrokerageProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, kind, slotKey, stateCode], map: "uniq_brokerage_checklist_slot")
  @@index([profileId, kind])
  @@map("brokerage_checklists")
}

/// State-specific contract rules (deadline math, default offsets).
/// Joined to BrokerageProfile so a brokerage can override the
/// REOS-default rules per state if their boilerplate differs.
model BrokerageStateConfig {
  id              String   @id @default(cuid())
  profileId       String   @map("profile_id")
  stateCode       String   @map("state_code") // 2-letter
  /// Free-form overrides — { walkthroughOffsetDays: -1,
  /// emDueBusinessDays: 3, inspectionDays: 10, ... }
  rulesJson       Json     @map("rules_json")
  createdAt       DateTime @default(now()) @map("created_at")

  profile BrokerageProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, stateCode], map: "uniq_brokerage_state")
  @@map("brokerage_state_configs")
}

/// Help questions — every /api/help call logs the question + the
/// AI answer. Drives a weekly "what are users stuck on?" digest
/// to Telegram so we know what features to build / clarify.
model HelpQuestion {
  id           String   @id @default(cuid())
  accountId    String   @map("account_id")
  userId       String?  @map("user_id")
  question     String
  answerText   String?  @map("answer_text")
  /// Coarse topic guess from a regex match against the question —
  /// used for grouping similar questions in the digest.
  topic        String?
  helpful      Boolean? // user thumb-up/down (later)
  createdAt    DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([topic])
  @@map("help_questions")
}

/// History of scan runs from /scan — what type, when, how many hits.
/// Drives the "since last scan" default + the recent-scans list.
model ScanRun {
  id            String    @id @default(cuid())
  accountId     String    @map("account_id")
  scanType      String    @map("scan_type") // contract | earnest_money | invoice | title_order | stale_contact | search | smart
  source        String    @default("gmail") // gmail | upload
  paramsJson    Json?     @map("params_json") // window, query, senders, etc.
  startedAt     DateTime  @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  hitsCount     Int       @default(0) @map("hits_count")
  errorText     String?   @map("error_text")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, startedAt])
  @@map("scan_runs")
}

/// Dedupe table for documents we've already forwarded to an external
/// transaction-management system (Dotloop, Rezen, etc.), so a re-run
/// doesn't email the same PDF twice.
model ForwardedDocument {
  id            String   @id @default(cuid())
  accountId     String   @map("account_id")
  transactionId String   @map("transaction_id")
  messageId     String   @map("message_id")
  attachmentId  String   @map("attachment_id")
  filename      String
  toEmail       String   @map("to_email")
  forwardedAt   DateTime @default(now()) @map("forwarded_at")

  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([transactionId, messageId, attachmentId], map: "uniq_forwarded_doc")
  @@index([accountId, forwardedAt])
  @@map("forwarded_documents")
}

model TransactionFinancials {
  id                     String   @id @default(cuid())
  transactionId          String   @unique @map("transaction_id")
  salePrice              Float?   @map("sale_price")
  commissionPercent      Float?   @map("commission_percent")
  grossCommission        Float?   @map("gross_commission")
  referralFeePercent     Float?   @map("referral_fee_percent")
  referralFeeAmount      Float?   @map("referral_fee_amount")
  brokerageSplitPercent  Float?   @map("brokerage_split_percent")
  brokerageSplitAmount   Float?   @map("brokerage_split_amount")
  marketingCostAllocated Float?   @map("marketing_cost_allocated")
  netCommission          Float?   @map("net_commission")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("transaction_financials")
}

/// Browser-issued Web Push subscription. One row per (user, device).
/// Endpoint is unique — re-subscribing from the same browser yields
/// the same endpoint, so we upsert on it.
model PushSubscription {
  id            String   @id @default(cuid())
  accountId     String   @map("account_id")
  userId        String   @map("user_id")
  endpoint      String   @unique
  p256dh        String
  auth          String
  /// User agent string captured at subscribe time, for debugging /
  /// "this is your iPhone 16" labelling in settings.
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")
  lastUsedAt    DateTime? @map("last_used_at")
  /// Set when the push endpoint returns 404 / 410 — we keep the row
  /// for audit but don't dispatch to it again.
  disabledAt    DateTime? @map("disabled_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId, userId])
  @@map("push_subscriptions")
}

/// User-scheduled inspection appointment(s) on a transaction.
/// Separate from Transaction.inspectionDate (which is the contract
/// DEADLINE) — this row is the actual visit booked with the inspector,
/// e.g. "General home — Tue 5/10 9am", "Pest — same morning",
/// "Radon — Wed pickup". Multiple per transaction.
model TransactionInspection {
  id              String   @id @default(cuid())
  transactionId   String   @map("transaction_id")
  /// Type of inspection — "general" | "pest" | "radon" | "sewer"
  /// | "chimney" | "pool" | "survey" | "other". UI exposes a
  /// freeform label; this slot is for analytics / templating later.
  kind            String   @default("other")
  /// Human label as the user typed it ("General home inspection").
  label           String
  /// When the appointment is. Nullable so a row can be created as a
  /// placeholder before the inspector confirms.
  scheduledAt     DateTime? @map("scheduled_at")
  /// Vendor company name — separated from notes so we can dedupe
  /// + autocomplete from past entries on the account ("Acme Inspections").
  vendorName      String?  @map("vendor_name")
  /// Free-form notes — phone, schedule details, special instructions.
  vendorNote      String?  @map("vendor_note")
  /// Linked CalendarEvent row (when the agent has hit Sync to
  /// calendar). NULL = not synced.
  calendarEventId String?  @map("calendar_event_id")
  /// User opt-in for Telegram reminders on this specific inspection.
  remindOnTelegram Boolean  @default(true) @map("remind_on_telegram")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  transaction     Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  calendarEvent   CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)

  @@index([transactionId, scheduledAt])
  @@map("transaction_inspections")
}


/// AccountMembership — the M:N join that lets a user belong to MORE
/// THAN their home account. A TC like Laura keeps `User.accountId`
/// as her own brokerage but holds AccountMembership rows for every
/// agent/brokerage that's contracted her. The active workspace is
/// chosen via the `reos_active_account` cookie, validated against
/// this table on every request.
///
/// Roles inside a host account:
///   - "owner"       : full admin — only the host's own User has this
///   - "coordinator" : standard TC access — read/write transactions,
///                     contacts, milestones; can NOT change billing /
///                     team / brokerage profile
///   - "agent"       : read-only for now (future: limited edit on
///                     deals they're assigned to)
model AccountMembership {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  /// Email used to identify the invitee before they sign up. Once
  /// they log in, createUser links the row by setting userId.
  email       String
  accountId   String   @map("account_id")
  role        String   @default("coordinator")
  invitedById String?  @map("invited_by_id")
  invitedAt   DateTime @default(now()) @map("invited_at")
  acceptedAt  DateTime? @map("accepted_at")
  revokedAt   DateTime? @map("revoked_at")

  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, email], map: "uniq_membership_account_email")
  @@index([userId])
  @@index([email])
  @@map("account_memberships")
}

/// Free-form notes attached to a transaction. Visible under AI
/// Summary on the detail page; the section badge shows a red dot
/// when there are unread notes for the active user.
///
/// readByJson = JSON array of userIds who have viewed the note since
/// it was created or last updated. The author is auto-marked as read.
model TransactionNote {
  id             String   @id @default(cuid())
  transactionId  String   @map("transaction_id")
  authorUserId   String?  @map("author_user_id")
  /// Plain-text body, capped at 8KB at the API layer.
  body           String
  /// JSON array of userIds — `[]` means nobody has read this note yet.
  readByJson     Json     @default("[]") @map("read_by_json")
  /// When true on create, the API fans the note out to the share-list
  /// emails as a transactional Gmail send. Off by default — a TC's
  /// quick scratch notes shouldn't email everyone.
  notifyEmail    Boolean  @default(false) @map("notify_email")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  author         User?       @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([transactionId, createdAt])
  @@map("transaction_notes")
}

/// Native esign — one row per signer on a request. The `token` is the
/// signer's bearer credential (crypto-random, emailed link). ESIGN
/// attribution evidence = token delivery to this email + ip/userAgent
/// captured at consent and signing.
model EsignRecipient {
  id                 String    @id @default(cuid())
  esignRequestId     String    @map("esign_request_id")
  name               String
  email              String
  signingOrder       Int       @default(1) @map("signing_order")
  token              String    @unique
  status             String    @default("pending") // pending, viewed, consented, signed, declined
  consentAt          DateTime? @map("consent_at")
  /// Version tag of the consent affirmation text shown (ESIGN evidence).
  consentTextVersion String?   @map("consent_text_version")
  viewedAt           DateTime? @map("viewed_at")
  signedAt           DateTime? @map("signed_at")
  ip                 String?
  userAgent          String?   @map("user_agent")
  /// PNG data URL of the captured signature (drawn or typed render).
  signatureImage     String?   @map("signature_image")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  esignRequest EsignRequest @relation(fields: [esignRequestId], references: [id], onDelete: Cascade)
  fields       EsignField[]
  events       EsignEvent[]

  @@index([esignRequestId])
  @@map("esign_recipients")
}

/// Native esign — a box placed on a page. Coordinates are normalized
/// 0..1 with TOP-LEFT origin relative to the page (UI convention).
/// pdf-lib uses bottom-left origin — EsignPdfService converts.
model EsignField {
  id             String  @id @default(cuid())
  esignRequestId String  @map("esign_request_id")
  recipientId    String  @map("recipient_id")
  type           String  // SIGNATURE, INITIALS, DATE_SIGNED, TEXT
  page           Int     // 1-based
  x              Float
  y              Float
  width          Float
  height         Float
  required       Boolean @default(true)
  /// Filled value for TEXT fields (set at signing time).
  value          String?

  esignRequest EsignRequest   @relation(fields: [esignRequestId], references: [id], onDelete: Cascade)
  recipient    EsignRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([esignRequestId])
  @@index([recipientId])
  @@map("esign_fields")
}

/// Native esign — append-only lifecycle audit trail. Feeds the audit
/// certificate page burned into the finalized PDF.
model EsignEvent {
  id             String   @id @default(cuid())
  esignRequestId String   @map("esign_request_id")
  recipientId    String?  @map("recipient_id")
  type           String   // created, sent, viewed, consented, signed, declined, completed, voided
  occurredAt     DateTime @default(now()) @map("occurred_at")
  ip             String?
  userAgent      String?  @map("user_agent")
  metaJson       Json?    @map("meta_json")

  esignRequest EsignRequest    @relation(fields: [esignRequestId], references: [id], onDelete: Cascade)
  recipient    EsignRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([esignRequestId, occurredAt])
  @@map("esign_events")
}

/// Layer 2 — Atlas learns from corrections. Each row is a field-level
/// extraction correction (what Atlas produced vs what a human set) grouped
/// by state + doc type. When the SAME correction recurs (weight >= threshold)
/// it is promoted to an ACTIVE rule whose `ruleText` is injected into future
/// extraction prompts for that state/docType. Token-efficient: only the
/// relevant, promoted rules are ever sent to the model — never the raw log.
model ExtractionLearning {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  /// US state the pattern applies to (e.g. "WY"); null = any state.
  state     String?
  docType   String   @default("purchase_contract") @map("doc_type")
  /// The field / entity the correction is about (e.g. "sellers", "side",
  /// "closingDate", "listing_agent").
  field     String
  /// "correction" = raw signal; "rule" = promoted, injectable guidance.
  kind      String   @default("correction")
  /// Short, normalized sample of the miss (never full document content).
  extracted String?
  corrected String?
  /// Generalized guidance injected into the extraction prompt (rules only).
  ruleText  String?  @map("rule_text")
  /// How many corrections support this pattern.
  weight    Int      @default(1)
  /// Active rules are injected; corrections below threshold are not.
  active    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([accountId, state, docType, field])
  @@index([accountId, active])
  @@map("extraction_learnings")
}
